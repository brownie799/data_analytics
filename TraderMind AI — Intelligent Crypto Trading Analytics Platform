        "\n",
        "plt.figure(figsize=(12,6))\n",
        "\n",
        "sns.histplot(\n",
        "    df['Size USD'],\n",
        "    bins=50,\n",
        "    kde=True,\n",
        "    color=SECONDARY\n",
