        "numeric_cols = [\n",
        "    'Execution Price',\n",
        "    'Size USD',\n",
        "    'Closed PnL',\n",
        "    'Fee'\n",
        "]\n",
        "\n",
        "corr = df[numeric_cols].corr()\n",
        "\n",
        "plt.figure(figsize=(10,7))\n",
        "\n",
        "sns.heatmap(\n",
