        "\n",
        "daily_profit = df.groupby(\n",
        "    'Date'\n",
        ")['Closed PnL'].sum()\n",
        "\n",
        "plt.figure(figsize=(15,6))\n",
        "\n",
        "plt.plot(\n",
        "    daily_profit,\n",
        "    color=WARNING,\n",
