        "\n",
        "plt.title(\n",
        "    \"Buy vs Sell Activity\",\n",
        "    fontsize=18,\n",
        "    fontweight='bold'\n",
        ")\n",
        "\n",
        "for p in ax.patches:\n",
        "    ax.annotate(\n",
