        "import ipywidgets as widgets\n",
        "from IPython.display import display, clear_output\n",
        "\n",
        "# Ensure df is available from the previous cell's execution\n",
        "# If df is not in the global scope (e.g., if the previous cell was not run fully),\n",
        "# you might need to re-load or define it here.\n",
        "\n",
        "def create_coin_dashboard(selected_coin):\n",
        "    clear_output(wait=True)\n",
        "    print(f\"Analyzing data for: {selected_coin}\")\n",
        "\n",
        "    if selected_coin == \"All Coins\":\n",
        "        filtered_df = df.copy()\n",
        "    else:\n",
        "        filtered_df = df[df['Coin'] == selected_coin].copy()\n",
        "\n",
        "    if filtered_df.empty:\n",
        "        print(\"No data available for the selected coin.\")\n",
        "        return\n",
        "\n",
        "    # Recalculate KPIs for the filtered data\n",
        "    total_trades_filtered = len(filtered_df)\n",
        "    total_profit_filtered = round(filtered_df['Closed PnL'].sum(), 2)\n",
        "    avg_trade_size_filtered = round(filtered_df['Size USD'].mean(), 2)\n",
        "    profitable_trades_filtered = len(filtered_df[filtered_df['Closed PnL'] > 0])\n",
        "    win_rate_filtered = round((profitable_trades_filtered / total_trades_filtered) * 100, 2) if total_trades_filtered > 0 else 0\n",
        "\n",
        "    print(\"\\n\" + \"=\"*70)\n",
        "    print(f\"         CRYPTO TRADING PERFORMANCE DASHBOARD - {selected_coin}\")\n",
        "    print(\"=\"*70)\n",
        "    print(f\"\"\"\n",
        "\n",
        "    📊 Total Trades            : {total_trades_filtered}\n",
        "\n",
        "    💰 Total Profit/Loss       : ${total_profit_filtered}\n",
        "\n",
        "    📈 Average Trade Size      : ${avg_trade_size_filtered}\n",
        "\n",
        "    ✅ Profitable Trades        : {profitable_trades_filtered}\n",
        "\n",
        "    🎯 Win Rate                : {win_rate_filtered}%\n",
        "\n",
        "    \"\"\")\n",
        "    print(\"=\"*70)\n",
        "\n",
        "    # Generate visualizations for the filtered data\n",
        "\n",
        "    # PROFIT / LOSS DISTRIBUTION\n",
        "    plt.figure(figsize=(12,6))\n",
        "    sns.histplot(\n",
        "        filtered_df['Closed PnL'],\n",
        "        bins=60,\n",
        "        kde=True,\n",
        "        color=PRIMARY\n",
        "    )\n",
        "    plt.title(f\"Profit & Loss Distribution for {selected_coin}\", fontsize=18, fontweight='bold')\n",
        "    plt.xlabel(\"Closed PnL\", fontsize=14)\n",
        "    plt.ylabel(\"Frequency\", fontsize=14)\n",
        "    plt.show()\n",
        "\n",
        "    # BUY VS SELL ANALYSIS\n",
        "    plt.figure(figsize=(8,5))\n",
        "    ax = sns.countplot(\n",
        "        x='Side',\n",
        "        data=filtered_df,\n",
        "        palette=[PRIMARY, ACCENT]\n",
        "    )\n",
        "    plt.title(f\"Buy vs Sell Activity for {selected_coin}\", fontsize=18, fontweight='bold')\n",
        "    for p in ax.patches:\n",
        "        ax.annotate(\n",
        "            f'{p.get_height()}',\n",
        "            (p.get_x() + 0.3, p.get_height() + 50),\n",
        "            fontsize=12\n",
        "        )\n",
        "    plt.show()\n",
        "\n",
        "    # DAILY PROFIT TREND\n",
        "    daily_profit_filtered = filtered_df.groupby('Date')['Closed PnL'].sum()\n",
        "    if not daily_profit_filtered.empty:\n",
        "        plt.figure(figsize=(15,6))\n",
        "        plt.plot(\n",
        "            daily_profit_filtered,\n",
        "            color=WARNING,\n",
        "            linewidth=3\n",
        "        )\n",
        "        plt.title(f\"Daily Profit Trend for {selected_coin}\", fontsize=18, fontweight='bold')\n",
        "        plt.xlabel(\"Date\")\n",
        "        plt.ylabel(\"Total Closed PnL\")\n",
        "        plt.xticks(rotation=45)\n",
        "        plt.grid(alpha=0.3)\n",
        "        plt.show()\n",
        "\n",
        "# Get unique coins for the dropdown\n",
        "coin_options = ['All Coins'] + sorted(df['Coin'].unique().tolist())\n",
        "\n",
        "# Create the interactive widget\n",
        "coin_selector = widgets.Dropdown(\n",
        "    options=coin_options,\n",
        "    value='All Coins',\n",
        "    description='Select Coin:',\n",
        "    disabled=False,\n",
        ")\n",
        "\n",
        "# Display the interactive dashboard\n",
        "widgets.interactive(create_coin_dashboard, selected_coin=coin_selector)"
